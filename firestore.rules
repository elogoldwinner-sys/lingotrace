rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function ownsClass(classId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/classes/$(classId)).data.teacherId == request.auth.uid;
    }

    // True if the signed-in user's own portal account (studentAccounts/{uid})
    // is linked to the given studentId — i.e. "is this me?" for a student.
    function isLinkedStudent(studentId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/studentAccounts/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/studentAccounts/$(request.auth.uid)).data.studentId == studentId;
    }

    // True if the signed-in user is a parent account linked to the given studentId.
    function isLinkedParent(studentId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/parents/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/parents/$(request.auth.uid)).data.studentId == studentId;
    }

    // Each teacher can read/write only their own profile document
    match /teachers/{uid} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }

    // A parent's portal account (doc id = their own auth uid)
    match /parents/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow create: if isSignedIn() && request.auth.uid == uid && request.resource.data.uid == uid;
      allow update, delete: if false;
    }

    // Maps a student's auth uid -> their roster studentId (doc id = their own auth uid)
    match /studentAccounts/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow create: if isSignedIn() && request.auth.uid == uid && request.resource.data.uid == uid;
      allow update, delete: if false;
    }

    // Class join links. Anyone with the exact token can read it (needed to
    // resolve /join/:token before the visitor has signed in) — the collection
    // is never listable, so a token must already be known to look it up.
    match /invites/{token} {
      allow get: if true;
      // A teacher looking up "do I already have an invite for this class+role"
      // (getOrCreateInvite) needs to run a `where(classId==, role==)` query.
      // That's a list operation, so it must be explicitly allowed here — this
      // was previously `if false`, which silently broke the invite-link
      // buttons (Firestore rejected the query with permission-denied before
      // any invite could ever be created or copied).
      allow list: if isSignedIn() && ownsClass(resource.data.classId);
      allow create: if ownsClass(request.resource.data.classId);
      allow update, delete: if false;
    }

    // A teacher can only manage classes they own
    match /classes/{classId} {
      allow read, update, delete: if isSignedIn() && resource.data.teacherId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.teacherId == request.auth.uid;
    }

    // Students belong to a class. The teacher who owns the class has full
    // access. A signed-in student/parent can read their own linked record.
    // Listing (without auth) is allowed so the public /join page can show a
    // "pick your name" / "pick your child" roster for a specific class —
    // note this means roster info (names, parent contact fields) for a class
    // is readable by anyone who knows its classId, not just invite holders.
    match /students/{studentId} {
      allow get: if ownsClass(resource.data.classId) ||
        isLinkedStudent(studentId) || isLinkedParent(studentId);
      allow list: if true;
      allow update: if ownsClass(resource.data.classId) ||
        (isSignedIn() && resource.data.authUid == null &&
          request.resource.data.authUid == request.auth.uid) ||
        (isLinkedParent(studentId) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(["parentName", "parentEmail"])) ||
        (isLinkedStudent(studentId) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(["photoURL"]));
      allow create: if ownsClass(request.resource.data.classId) ||
        (isSignedIn() && request.resource.data.authUid == request.auth.uid);
      allow delete: if ownsClass(resource.data.classId);
    }

    match /attendance/{recordId} {
      allow read: if ownsClass(resource.data.classId) ||
        isLinkedStudent(resource.data.studentId) || isLinkedParent(resource.data.studentId);
      allow update, delete: if ownsClass(resource.data.classId);
      allow create: if ownsClass(request.resource.data.classId);
    }

    match /sessions/{sessionId} {
      allow read, update, delete: if ownsClass(resource.data.classId);
      allow create: if ownsClass(request.resource.data.classId);
    }

    // Notes are owned directly by the teacher who authored them. A parent may
    // also read a note about their child once it's marked visibleToParent.
    match /notes/{noteId} {
      allow read: if (isSignedIn() && resource.data.authorId == request.auth.uid) ||
        (resource.data.visibleToParent == true && isLinkedParent(resource.data.studentId));
      allow update, delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
    }

    // Points transactions are owned by the teacher who awarded them. The
    // student they're about, or that student's parent, may also read them.
    match /pointsTransactions/{txnId} {
      allow read: if (isSignedIn() && resource.data.awardedBy == request.auth.uid) ||
        isLinkedStudent(resource.data.studentId) || isLinkedParent(resource.data.studentId);
      allow update, delete: if isSignedIn() && resource.data.awardedBy == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.awardedBy == request.auth.uid;
    }

    // Notifications belong to the teacher they were sent to
    match /notifications/{notificationId} {
      allow read, update, delete: if isSignedIn() && resource.data.recipientId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.recipientId == request.auth.uid;
    }
  }
}
