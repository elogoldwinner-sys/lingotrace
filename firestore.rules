rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Each teacher can read/write only their own profile document
    match /teachers/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Add rules for your other collections (classes, students, sessions, etc.)
    // as needed — default deny applies to anything not explicitly matched.
  }
}
